---
import BaseLayout from '../layouts/BaseLayout.astro';
const repo = 'https://github.com/XJTUCS-HUB/XJTUCS-Guide';
const methods = [
  { index: '01', title: 'GitHub Issue', fit: '不熟悉 Git', text: '按表单提交课程资料、学习体验、推免经验或普通纠错。', href: `${repo}/issues/new/choose`, action: '选择投稿表单' },
  { index: '02', title: '编辑此页', fit: '会简单 Markdown', text: '在 GitHub 网页中修正错字、失效链接或补充一小段内容。', href: repo, action: '打开项目仓库' },
  { index: '03', title: 'Pull Request', fit: '熟悉 Git', text: '使用内容模板批量新增课程资料，并在本地完成构建检查。', href: `${repo}/blob/main/CONTRIBUTING.md`, action: '阅读贡献指南' },
];
---
<BaseLayout title="参与贡献 · XJTUCS Guide">
  <header class="page-head">
    <div class="container head-grid">
      <div><p class="eyebrow">Contribute</p><h1 class="serif">参与贡献</h1></div>
      <p>不会 Git 也可以投稿。选择适合你的方式，提供必要的作者、来源与适用时间，剩余格式由维护者协助整理。</p>
    </div>
  </header>

  <main class="container contribution-body">
    <section aria-labelledby="methods-title">
      <div class="section-title"><div><p class="eyebrow">Start here</p><h2 id="methods-title" class="serif">选择贡献方式</h2></div><span>三种入口</span></div>
      <ol class="method-list">
        {methods.map((method) => <li><span class="index">{method.index}</span><div><h3>{method.title}</h3><small>{method.fit}</small></div><p>{method.text}</p><a href={method.href}>{method.action} →</a></li>)}
      </ol>
    </section>

    <section class="check-section" aria-labelledby="check-title">
      <div><p class="eyebrow">Before submitting</p><h2 id="check-title" class="serif">提交前检查</h2><p>这些信息足以让一份投稿进入整理流程。</p></div>
      <ul><li>课程名称与代码</li><li>内容类型与标题</li><li>作者或原始来源</li><li>正文、资料链接或修改建议</li><li>适用学期、教师或版本（如有）</li></ul>
    </section>

    <section aria-labelledby="templates-title">
      <div class="section-title"><div><p class="eyebrow">Templates</p><h2 id="templates-title" class="serif">示例与模板</h2></div><span>Markdown</span></div>
      <div class="link-table">
        <a href={`${repo}/blob/main/docs/templates/course-resource.md`}><span>课程资料模板</span><small>笔记、实验、考核与外部资源</small><b>→</b></a>
        <a href={`${repo}/blob/main/docs/templates/course-experience.md`}><span>课程学习体验模板</span><small>课程组织、工作量、难点与建议</small><b>→</b></a>
        <a href={`${repo}/blob/main/docs/templates/recommendation-experience.md`}><span>推免经验模板</span><small>准备过程、申请经历与踩坑</small><b>→</b></a>
      </div>
    </section>

    <section class="policy-band" aria-labelledby="policy-title">
      <div><p class="eyebrow">Content policy</p><h2 id="policy-title" class="serif">内容边界</h2></div>
      <div><p>可以提交原创笔记、学习体验、实验方法、公开资料和合法外链。转载内容必须保留作者、原链接和许可证。</p><p>不要提交个人隐私、未公开试题、盗版教材、未经授权的整套课件或可直接提交的当前作业成品。</p><p>隐私、版权、安全等不适合公开讨论的事项，请发送至 <a href="mailto:XJTUCS-HUB@protonmail.com">XJTUCS-HUB@protonmail.com</a>。</p><nav><a href={`${repo}/blob/main/CONTENT-POLICY.md`}>内容政策</a><a href={`${repo}/blob/main/PRIVACY.md`}>隐私说明</a><a href={`${repo}/blob/main/TAKEDOWN.md`}>投诉与下架</a></nav></div>
    </section>
  </main>
</BaseLayout>

<style>
  .page-head { padding-block: 88px 64px; border-bottom: 1px solid var(--line); }
  .head-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: end; }
  h1 { margin: 7px 0 0; font-size: 5.4rem; font-weight: 500; line-height: 1; }
  .head-grid > p { max-width: 540px; margin: 0; color: var(--muted); font-size: 1.05rem; }
  .contribution-body { display: grid; gap: 88px; padding-block: 78px 110px; }
  .section-title { display: flex; justify-content: space-between; align-items: end; padding-bottom: 18px; border-bottom: 1px solid var(--ink); }
  h2 { margin: 4px 0 0; font-size: 2.35rem; font-weight: 500; line-height: 1.1; }
  .section-title > span { color: var(--muted); font-size: .78rem; }
  .method-list { margin: 0; padding: 0; list-style: none; }
  .method-list li { min-height: 104px; display: grid; grid-template-columns: 50px 180px minmax(260px, 1fr) 150px; gap: 22px; align-items: center; border-bottom: 1px solid var(--line); }
  .index { color: var(--brand); font-family: var(--serif); font-size: 1.35rem; }
  h3 { margin: 0; font-family: var(--serif); font-size: 1.15rem; font-weight: 600; }
  .method-list small { color: var(--muted); }
  .method-list p { color: var(--muted); }
  .method-list a { color: var(--link); text-align: right; }
  .check-section { display: grid; grid-template-columns: .8fr 1.2fr; gap: 80px; padding: 48px 0; border-block: 1px solid var(--line); }
  .check-section p { color: var(--muted); }
  .check-section ul { display: grid; grid-template-columns: 1fr 1fr; gap: 0 34px; margin: 0; padding: 0; list-style: none; }
  .check-section li { padding: 13px 0; border-bottom: 1px solid var(--line); }
  .link-table { border-bottom: 1px solid var(--line); }
  .link-table a { min-height: 68px; display: grid; grid-template-columns: 220px 1fr 20px; align-items: center; gap: 20px; padding: 8px 12px; border-top: 1px solid var(--line); transition: background 150ms var(--ease); }
  .link-table a:hover { background: var(--brand-soft); }
  .link-table small { color: var(--muted); }
  .link-table b { color: var(--brand); font-weight: 400; }
  .policy-band { display: grid; grid-template-columns: .8fr 1.2fr; gap: 80px; padding: 52px 0; border-top: 1px solid var(--ink); }
  .policy-band p { max-width: 680px; color: var(--muted); }
  .policy-band nav { display: flex; flex-wrap: wrap; gap: 12px 24px; margin-top: 24px; }
  .policy-band a { color: var(--link); }
  @media (max-width: 820px) { .head-grid, .check-section, .policy-band { grid-template-columns: 1fr; gap: 26px; } .method-list li { grid-template-columns: 42px 1fr auto; padding-block: 18px; } .method-list p { grid-column: 2 / 4; margin: 0; } .method-list a { grid-column: 2 / 4; text-align: left; } }
  @media (max-width: 560px) { .page-head { padding-block: 58px 44px; } h1 { font-size: 3.5rem; } .contribution-body { gap: 68px; padding-top: 54px; } .check-section ul { grid-template-columns: 1fr; } .link-table a { grid-template-columns: 1fr 20px; padding-block: 14px; } .link-table small { grid-column: 1; } .link-table b { grid-column: 2; grid-row: 1 / 3; } }
</style>
