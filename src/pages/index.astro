---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseRow from '../components/CourseRow.astro';
import { withBase } from '../lib/paths';
const courses = [
  ['COMP400727', '计算机系统导论', '4', '系统结构', '/courses/comp400727/'],
  ['COMP400505', '数据结构与算法 I', '4', '专业基础', '/courses/comp400505/'],
  ['EELC400105', '数字逻辑电路 I', '3.5', '专业基础', '/courses/eelc400105/'],
  ['COMP450205', '操作系统原理 I', '3', '专业核心', '/courses/comp450205/'],
  ['COMP462205', '算法分析与设计', '2.5', '专业核心', '/courses/comp462205/'],
];
---
<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">XJTU · Computer Science</p>
        <h1 class="serif">西安交通大学<br />计算机课程指南</h1>
        <p class="lede">由计算机专业学生共同维护，汇集课程介绍、学习资料与经验。</p>
        <div class="quick-links"><span>常用入口</span><a href={withBase('/courses/')}>专业必修</a><a href={withBase('/courses/')}>专业选修</a><a href={withBase('/contribute/')}>提交资料</a></div>
      </div>
      <aside class="course-map" aria-label="课程方向">
        <div class="map-head"><span>课程索引</span><small>按培养方案分类</small></div>
        <a href={withBase('/courses/')}><strong>01</strong><span>专业基础</span><small>离散数学 · 程序设计 · 数据结构</small></a>
        <a href={withBase('/courses/')}><strong>02</strong><span>专业核心</span><small>组成 · 系统 · 编译 · 网络</small></a>
        <a href={withBase('/courses/')}><strong>03</strong><span>专业选修</span><small>软件理论 · 系统结构 · AI · 网络</small></a>
      </aside>
    </div>
  </section>

  <section class="courses-section container">
    <div class="section-heading">
      <div><p class="eyebrow">Course catalog</p><h2 class="serif">从课程开始</h2></div>
      <p>先找到课程，再查看与教师、学期相关的资料上下文。</p>
    </div>
    <div class="filters" aria-label="课程筛选">
      <button class="active">全部</button><button>专业基础</button><button>专业核心</button><button>专业选修</button>
      <a href={withBase('/courses/')}>查看完整目录 →</a>
    </div>
    <div class="course-list">
      {courses.map(([code, name, credits, category, href]) => <CourseRow code={code} name={name} credits={credits} category={category} href={withBase(href)} />)}
    </div>
  </section>

  <section class="updates-band">
    <div class="container updates-grid">
      <div><p class="eyebrow">Recently updated</p><h2 class="serif">最近整理</h2></div>
      <ol>
        <li><time>待填充</time><a href={withBase('/courses/comp450205/')}>首批课程内容整理中</a><span>课程资料</span></li>
        <li><time>待填充</time><a href={withBase('/contribute/')}>贡献方式与内容边界</a><span>项目说明</span></li>
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { min-height: 610px; display: grid; align-items: center; border-bottom: 1px solid var(--line); }
  .hero-grid { display: grid; grid-template-columns: 1.35fr .65fr; gap: 80px; align-items: center; padding-block: 70px; }
  h1 { max-width: 760px; margin: 14px 0 22px; font-size: 5.6rem; font-weight: 500; line-height: .98; letter-spacing: 0; text-wrap: balance; }
  .lede { max-width: 650px; margin: 0 0 30px; color: var(--muted); font-size: 1.05rem; }
  .quick-links { display: flex; flex-wrap: wrap; gap: 8px 18px; margin-top: 16px; color: var(--muted); font-size: .8rem; }
  .quick-links a { color: var(--link); }
  .course-map { border: 1px solid var(--line-strong); background: color-mix(in srgb, var(--surface) 92%, transparent); }
  .map-head { min-height: 48px; display: flex; justify-content: space-between; align-items: center; padding: 0 14px; border-bottom: 1px solid var(--line); font-size: .78rem; }
  .map-head small { color: var(--muted); }
  .course-map a { min-height: 90px; display: grid; grid-template-columns: 38px 1fr; gap: 2px 10px; align-content: center; padding: 12px 16px; border-bottom: 1px solid var(--line); transition: background 160ms var(--ease); }
  .course-map a:last-child { border-bottom: 0; }
  .course-map a:hover { background: var(--brand-soft); }
  .course-map strong { grid-row: 1 / 3; color: var(--brand); font-family: var(--serif); font-size: 1.4rem; font-weight: 500; }
  .course-map span { font-family: var(--serif); font-size: 1.05rem; font-weight: 600; }
  .course-map small { color: var(--muted); }
  .courses-section { padding-block: 88px; }
  .section-heading { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: end; margin-bottom: 34px; }
  h2 { margin: 4px 0 0; font-size: 2.5rem; line-height: 1.1; font-weight: 500; }
  .section-heading > p { max-width: 500px; margin: 0; color: var(--muted); justify-self: end; }
  .filters { display: flex; align-items: center; gap: 4px; min-height: 48px; border-bottom: 1px solid var(--ink); }
  .filters button { min-height: 36px; padding: 0 12px; border: 0; background: transparent; color: var(--muted); cursor: pointer; }
  .filters button:hover, .filters button.active { background: var(--ink); color: var(--paper); }
  .filters a { margin-left: auto; color: var(--link); font-size: .82rem; }
  .updates-band { padding-block: 72px; border-block: 1px solid var(--line); background: var(--surface); }
  .updates-grid { display: grid; grid-template-columns: .72fr 1.28fr; gap: 80px; }
  .updates-grid ol { margin: 0; padding: 0; list-style: none; border-top: 1px solid var(--ink); }
  .updates-grid li { min-height: 64px; display: grid; grid-template-columns: 90px 1fr auto; align-items: center; gap: 16px; border-bottom: 1px solid var(--line); font-size: .88rem; }
  .updates-grid time, .updates-grid span { color: var(--muted); font-size: .75rem; }
  .updates-grid a:hover { color: var(--brand); }
  :global(html[data-variant="reading"]) .hero-grid { grid-template-columns: 1fr; max-width: 900px; }
  :global(html[data-variant="reading"]) .course-map { display: none; }
  :global(html[data-variant="notes"]) .hero { background-color: var(--surface); }
  :global(html[data-variant="notes"]) .course-list { display: grid; grid-template-columns: 1fr 1fr; gap: 0 8px; margin-top: 10px; }
  @media (max-width: 860px) { .hero-grid { grid-template-columns: 1fr; gap: 40px; } .hero { min-height: 0; } .course-map { display: none; } .updates-grid { grid-template-columns: 1fr; gap: 32px; } h1 { font-size: 4.4rem; } }
  @media (max-width: 680px) { .hero-grid { padding-block: 56px; } h1 { font-size: 3.15rem; } .section-heading { grid-template-columns: 1fr; gap: 14px; } .section-heading > p { justify-self: auto; } .filters { overflow-x: auto; } .filters button { white-space: nowrap; } .filters a { display: none; } :global(html[data-variant="notes"]) .course-list { grid-template-columns: 1fr; } .updates-grid li { grid-template-columns: 1fr auto; padding-block: 12px; } .updates-grid time { grid-column: 1 / 3; } }
</style>
