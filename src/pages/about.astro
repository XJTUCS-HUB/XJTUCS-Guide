---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="关于 · XJTUCS Guide"><section class="container simple-page"><p class="eyebrow">About</p><h1 class="serif">关于本站</h1><p>XJTUCS Guide 是由西安交通大学计算机专业学生维护的非官方课程资料站，不代表学校、学院或课程团队。</p></section></BaseLayout>
<style>.simple-page{min-height:60vh;padding-block:80px;max-width:760px}h1{margin:8px 0 18px;font-size:5.5rem;font-weight:500;line-height:1}.simple-page>p:last-child{color:var(--muted);font-size:1.05rem}@media(max-width:680px){h1{font-size:3.4rem}}</style>
