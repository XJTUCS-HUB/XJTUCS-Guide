---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CourseRow from '../../components/CourseRow.astro';
import ScrollSpy from '../../components/ScrollSpy.astro';
import { withBase } from '../../lib/paths';

const categoryOrder = ['专业基础', '专业核心', '专业选修'];
const categoryIds = new Map([
  ['专业基础', 'required-foundation'],
  ['专业核心', 'required-core'],
  ['专业选修', 'elective'],
]);
const categoryRank = (category: string) => {
  const index = categoryOrder.indexOf(category);
  return index === -1 ? 999 : index;
};
const categoryId = (category: string) => {
  const asciiSlug = category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  return categoryIds.get(category) ?? `category-${asciiSlug || encodeURIComponent(category)}`;
};
const courses = (await getCollection('courses')).sort((a, b) =>
  categoryRank(a.data.category) - categoryRank(b.data.category) ||
  a.data.category.localeCompare(b.data.category, 'zh-CN') ||
  a.data.code.localeCompare(b.data.code, 'zh-CN')
);
const categoryMap = new Map<string, typeof courses>();
for (const course of courses) {
  const items = categoryMap.get(course.data.category) ?? [];
  items.push(course);
  categoryMap.set(course.data.category, items);
}
const groups = [...categoryMap.entries()]
  .sort(([a], [b]) => {
    return categoryRank(a) - categoryRank(b) || a.localeCompare(b, 'zh-CN');
  })
  .map(([title, items]) => ({ title, id: categoryId(title), items }));
const courseHref = (id: string) => withBase(`/courses/${id}/`);
const creditsLabel = (credits?: number) => credits ?? '待核对';
---
<BaseLayout title="课程目录 · XJTUCS Guide">
  <div class="container catalog-layout">
    <aside class="catalog-nav"><p class="eyebrow">课程目录</p>{groups.map(({ title, id }) => <a href={`#${id}`} data-nav-link data-scrollspy-link>{title}</a>)}<hr /><small>按培养方案分类，不按学期组织</small></aside>
    <section>
      <div class="page-head"><p class="eyebrow">Course catalog</p><h1 class="serif">课程</h1><p>先选择课程，再查看对应的资料与学习体验。</p></div>
      <div class="catalog-search"><label for="course-type">课程类型</label><select id="course-type" aria-label="课程类型"><option value="all">全部类型</option><option value="required">专业必修</option><option value="elective">专业选修</option></select></div>
      {groups.map(({ title, id, items }) => <section class="group" id={id} data-course-group><div class="group-title"><h2 class="serif">{title}</h2><span data-count>{items.length} 门</span></div>{items.map((course) => <CourseRow code={course.data.code} name={course.data.name} credits={creditsLabel(course.data.credits)} category={title} requirement={course.data.requirement} href={courseHref(course.id)} />)}</section>)}
      <p class="no-results" hidden>没有匹配的课程，请尝试其他名称、代码或类型。</p>
    </section>
  </div>
  <ScrollSpy />
</BaseLayout>
<style>
  .catalog-layout { display: grid; grid-template-columns: 190px 1fr; gap: 64px; padding-block: 64px 100px; }
  .catalog-nav { position: sticky; top: 96px; height: fit-content; display: grid; gap: 4px; }
  .catalog-nav a { min-height: 40px; display: flex; align-items: center; padding: 0 10px; color: var(--muted); border-left: 2px solid transparent; }
  .catalog-nav a:hover, .catalog-nav a.active { color: var(--ink); border-color: var(--brand); }
  .catalog-nav hr { width: 100%; border: 0; border-top: 1px solid var(--line); }
  .catalog-nav small { color: var(--muted); }
  .page-head { padding-bottom: 36px; }
  h1 { margin: 4px 0 10px; font-size: 5rem; line-height: 1; font-weight: 500; }
  .page-head p:last-child { color: var(--muted); }
  .catalog-search { min-height: 54px; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 0 14px; border: 1px solid var(--line-strong); background: var(--surface); }
  .catalog-search label { color: var(--muted); font-size: .8rem; }
  .catalog-search select { height: 42px; border: 0; outline: 0; background: transparent; color: var(--ink); }
  .group { padding-top: 54px; scroll-margin-top: 96px; }
  .group-title { display: flex; align-items: end; justify-content: space-between; padding-bottom: 12px; border-bottom: 1px solid var(--ink); }
  .group-title h2 { margin: 0; font-size: 1.8rem; font-weight: 500; }
  .group-title span { color: var(--muted); font-size: .78rem; }
  .no-results { margin: 54px 0 0; padding: 28px 0; border-block: 1px solid var(--line); color: var(--muted); }
  @media (max-width: 760px) { .catalog-layout { grid-template-columns: 1fr; gap: 20px; padding-top: 40px; } .catalog-nav { position: static; display: flex; overflow-x: auto; } .catalog-nav .eyebrow, .catalog-nav hr, .catalog-nav small { display: none; } .catalog-nav a { white-space: nowrap; border-left: 0; border-bottom: 2px solid transparent; } h1 { font-size: 3.5rem; } }
</style>

<script>
  const type = document.querySelector<HTMLSelectElement>('#course-type');
  const rows = [...document.querySelectorAll<HTMLElement>('[data-course-row]')];
  const groups = [...document.querySelectorAll<HTMLElement>('[data-course-group]')];
  const empty = document.querySelector<HTMLElement>('.no-results');
  const navLinks = [...document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]')];

  const syncNav = () => {
    navLinks.forEach((link) => {
      const targetId = link.getAttribute('href')?.replace('#', '');
      if (targetId) link.hidden = !groups.some((group) => group.id === targetId && !group.hidden);
    });
    window.dispatchEvent(new Event('scrollspy:update'));
  };

  const filterCourses = () => {
    const requirement = type?.value ?? 'all';
    rows.forEach((row) => {
      row.hidden = !(requirement === 'all' || row.dataset.requirement === requirement);
    });
    let visibleTotal = 0;
    groups.forEach((group) => {
      const visible = [...group.querySelectorAll<HTMLElement>('[data-course-row]')].filter((row) => !row.hidden).length;
      group.hidden = visible === 0;
      const count = group.querySelector<HTMLElement>('[data-count]');
      if (count) count.textContent = `${visible} 门`;
      visibleTotal += visible;
    });
    if (empty) empty.hidden = visibleTotal !== 0;
    syncNav();
  };
  type?.addEventListener('change', filterCourses);
  window.addEventListener('hashchange', syncNav);
  filterCourses();
</script>
